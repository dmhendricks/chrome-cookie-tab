{
   "background": {
      "service_worker": "background.js"
   },
   "devtools_page": "devtools-page.html",
   "description": "Missing cookie manager for Google Chrome. Edit and create cookies right in the Developer Tools.",
   "homepage_url": "http://www.bigbadgoose.com/cookie-inspector",
   "icons": {
      "128": "store-icon-128.png"
   },
   "manifest_version": 3,
   "minimum_chrome_version": "88",
   "name": "Cookie Inspector",
   "permissions": [
     "cookies",
     "tabs",
     "unlimitedStorage",
     "webNavigation"
   ],
   "host_permissions": [
     "*://*/*",
     "http://*/*",
     "https://*/*"
   ],
   "version": "2.0.9"
}
